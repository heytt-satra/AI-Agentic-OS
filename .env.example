# Jarvis-OS environment config.
# 1. Copy this file to ".env"  (cp .env.example .env)
# 2. Get a key at https://openrouter.ai/keys  (add a few dollars of credit)
# 3. Paste it after the = below. The .env file is git-ignored; your key stays local.

OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: override the model. Default is the cheap DeepSeek V4 Flash.
# Any OpenRouter slug works, e.g. anthropic/claude-sonnet-4.6 for the strong brain.
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash
