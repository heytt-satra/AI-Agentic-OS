# Jarvis-OS environment config.
# 1. Copy this file to ".env"  (cp .env.example .env)
# 2. Get a key at https://openrouter.ai/keys  (add a few dollars of credit)
# 3. Paste it after the = below. The .env file is git-ignored; your key stays local.

OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: override the model. Default is the cheap DeepSeek V4 Flash.
# Any OpenRouter slug works, e.g. anthropic/claude-sonnet-4.6 for the strong brain.
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Vision model for the see_screen tool (DeepSeek can't do images). Set this to a
# vision-capable OpenRouter slug if the default errors.
# OPENROUTER_VISION_MODEL=openai/gpt-4o-mini

# Run a LOCAL model instead (Ollama): point the base URL at it, no other change.
# OPENROUTER_BASE_URL=http://localhost:11434/v1

# Reliable web search for lead-gen/research. Without this, web_search falls back
# to scraping DuckDuckGo, which rate-limits under heavy use. Get a free key
# (2,000 queries/month) at https://brave.com/search/api/ and paste it here.
# BRAVE_API_KEY=your-brave-key-here
