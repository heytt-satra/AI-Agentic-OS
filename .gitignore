/target

# local secrets - never commit
.env

# agent scratch space
/workspace

# local sqlite db
/jarvis.db
/jarvis.db-wal
/jarvis.db-shm

# exported training data - private conversation history, never commit
/jarvis-dataset.jsonl
*.jsonl

# MCP server config - user-specific (may hold tokens), never commit
/mcp.json

# local encryption key for at-rest data - NEVER commit (losing it loses the data)
/.jarvis-key

# python bytecode
scripts/__pycache__/
__pycache__/
*.pyc
